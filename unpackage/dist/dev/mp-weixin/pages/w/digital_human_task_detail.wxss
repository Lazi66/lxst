
.page-container.data-v-00b1f751 {
    background-color: #f8f9fa;
    min-height: 100vh;
}
.p-30.data-v-00b1f751 { padding: 30rpx;
}
.m-b-20.data-v-00b1f751 { margin-bottom: 20rpx;
}
.m-b-30.data-v-00b1f751 { margin-bottom: 30rpx;
}
.p-b-safe.data-v-00b1f751 { height: env(safe-area-inset-bottom); padding-bottom: 40rpx;
}
.x.data-v-00b1f751 { display: flex; flex-direction: row;
}
.y.data-v-00b1f751 { display: flex; flex-direction: column;
}
.c.data-v-00b1f751 { align-items: center; justify-content: center;
}
.c-y.data-v-00b1f751 { align-items: center;
}
.jc-sb.data-v-00b1f751 { justify-content: space-between;
}
.status-card.data-v-00b1f751 {
    background: #fff;
    border-radius: 20rpx;
    padding: 30rpx 40rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.status-card.status-done .status-value.data-v-00b1f751 { color: #18D08D;
}
.status-card.status-fail .status-value.data-v-00b1f751 { color: #ff4d4f;
}
.status-card.status-ing .status-value.data-v-00b1f751 { color: #3A5DFB;
}
.status-row.data-v-00b1f751 {
    padding: 20rpx 0;
    border-bottom: 1px solid #f2f2f2;
}
.status-row.border-none.data-v-00b1f751 { border-bottom: none;
}
.status-label.data-v-00b1f751 {
    font-size: 28rpx;
    color: #999;
}
.status-value.data-v-00b1f751 {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
}
.info-card.data-v-00b1f751 {
    background: #fff5f5;
    border-radius: 20rpx;
    padding: 24rpx 30rpx;
}
.info-title.data-v-00b1f751 {
    font-size: 26rpx;
    color: #ff4d4f;
    margin-bottom: 12rpx;
}
.info-desc.data-v-00b1f751 {
    font-size: 26rpx;
    color: #666;
}
.section-card.data-v-00b1f751 {
    background: #fff;
    border-radius: 20rpx;
    padding: 30rpx 40rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}
.section-title.data-v-00b1f751 {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 24rpx;
}
.preview-row.data-v-00b1f751 {
    margin-bottom: 24rpx;
}
.preview-row.data-v-00b1f751:last-child { margin-bottom: 0;
}
.preview-label.data-v-00b1f751 {
    font-size: 26rpx;
    color: #999;
    margin-bottom: 12rpx;
}
.preview-box.data-v-00b1f751 {
    width: 200rpx;
    height: 200rpx;
    border-radius: 12rpx;
    overflow: hidden;
    background: #f5f6f8;
}
.preview-img.data-v-00b1f751 {
    width: 100%;
    height: 100%;
}
.preview-empty.data-v-00b1f751, .preview-desc.data-v-00b1f751 {
    font-size: 28rpx;
    color: #666;
}
.result-cover.data-v-00b1f751 {
    width: 100%;
    max-width: 400rpx;
    border-radius: 12rpx;
    overflow: hidden;
    background: #f5f6f8;
}
.result-cover-img.data-v-00b1f751 {
    width: 100%;
    display: block;
}
.result-video-el.data-v-00b1f751 {
    width: 100%;
    height: 360rpx;
    border-radius: 12rpx;
    background: #000;
}
/* 仅显示播放按钮 */
.audio-play-wrap.data-v-00b1f751 {
    display: flex;
    align-items: center;
}
.audio-play-btn.data-v-00b1f751 {
    width: 96rpx;
    height: 96rpx;
    border-radius: 50%;
    background: #3A5DFB;
    display: flex;
    align-items: center;
    justify-content: center;
}
.audio-play-icon.data-v-00b1f751 {
    font-size: 28rpx;
    color: #fff;
}
.result-id.data-v-00b1f751 { margin-top: 20rpx;
}
.m-t-30.data-v-00b1f751 { margin-top: 30rpx;
}
.m-l-10.data-v-00b1f751 { margin-left: 10rpx;
}
.download-btn.data-v-00b1f751 {
    background: #3A5DFB;
    color: #fff;
    font-size: 28rpx;
    padding: 20rpx 60rpx;
    border-radius: 100rpx;
    font-weight: 500;
}
.download-btn.data-v-00b1f751:active {
    opacity: 0.8;
}
.loading-text.data-v-00b1f751, .load-fail-text.data-v-00b1f751 {
    font-size: 28rpx;
    color: #999;
    padding: 60rpx 0;
}
.load-fail-text.data-v-00b1f751 { color: #ff4d4f;
}

