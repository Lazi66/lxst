
.page-container.data-v-09f76a21 {
    background: linear-gradient(180deg, #e8f5e9 0%, #f8f9fa 15%, #f8f9fa 100%);
    min-height: 100vh;
}
.x.data-v-09f76a21 { display: flex; flex-direction: row;
}
.y.data-v-09f76a21 { display: flex; flex-direction: column;
}
.c.data-v-09f76a21 { display: flex; align-items: center; justify-content: center;
}
.c-y.data-v-09f76a21 { align-items: center;
}
.jc-sb.data-v-09f76a21 { justify-content: space-between;
}
.flex-1.data-v-09f76a21 { flex: 1;
}
.flex-wrap.data-v-09f76a21 { flex-wrap: wrap;
}
.m-l-10.data-v-09f76a21 { margin-left: 10rpx;
}
.content-wrap.data-v-09f76a21 {
    padding: 0 30rpx;
    padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}
/* 横向滚动标签 */
.type-scroll.data-v-09f76a21 {
    width: 100%;
    white-space: nowrap;
    margin: 20rpx 0 30rpx;
}
.type-list.data-v-09f76a21 {
    display: inline-flex;
    padding: 0 4rpx;
}
.type-item.data-v-09f76a21 {
    background: #fff;
    padding: 16rpx 32rpx;
    border-radius: 12rpx;
    margin-right: 20rpx;
    border: 2rpx solid transparent;
    transition: all 0.2s;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}
.type-item.active.data-v-09f76a21 {
    border-color: #1677FF;
    background: rgba(22, 119, 255, 0.05);
}
.type-item.active .type-name.data-v-09f76a21 {
    color: #333;
    font-weight: bold;
}
.type-icon.data-v-09f76a21 {
    font-size: 32rpx;
    margin-right: 8rpx;
}
.type-name.data-v-09f76a21 {
    font-size: 28rpx;
    color: #666;
}
/* 输入区域 */
.input-section.data-v-09f76a21 {
    background: #fff;
    border-radius: 20rpx;
    padding: 30rpx;
    min-height: 400rpx;
    margin-bottom: 40rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}
.main-textarea.data-v-09f76a21 {
    width: 100%;
    flex: 1;
    font-size: 30rpx;
    color: #333;
    line-height: 1.6;
}
.ph-style.data-v-09f76a21 {
    color: #bbb;
}
.random-btn-wrap.data-v-09f76a21 {
    margin-top: 20rpx;
}
.random-btn.data-v-09f76a21 {
    background: #f5f5f5;
    padding: 12rpx 24rpx;
    border-radius: 8rpx;
    align-self: flex-start;
}
.random-text.data-v-09f76a21 {
    font-size: 26rpx;
    color: #666;
}
/* 字数等设置区域 */
.setting-section.data-v-09f76a21 {
    margin-bottom: 50rpx;
}
.setting-title.data-v-09f76a21 {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 24rpx;
}
.length-options.data-v-09f76a21 {
    gap: 20rpx;
    margin-bottom: 20rpx;
}
.length-item.data-v-09f76a21 {
    width: calc((100% - 40rpx) / 3);
    height: 72rpx;
    background: #fff;
    border-radius: 12rpx;
    font-size: 28rpx;
    color: #666;
    border: 2rpx solid transparent;
    transition: all 0.2s;
}
.length-item.active.data-v-09f76a21 {
    border-color: #1677FF;
    color: #1677FF;
    font-weight: bold;
    background: rgba(22, 119, 255, 0.05);
}
.length-desc.data-v-09f76a21 {
    font-size: 26rpx;
    color: #999;
}
/* 自定义字数输入框 */
.custom-input-wrap.data-v-09f76a21 {
    width: 100%;
    height: 100%;
    justify-content: center;
}
.custom-input.data-v-09f76a21 {
    width: 120rpx;
    height: 100%;
    font-size: 28rpx;
    text-align: center;
    color: #1677FF;
}
.custom-ph.data-v-09f76a21 {
    color: #aebce5;
}
.custom-unit.data-v-09f76a21 {
    color: #1677FF;
    font-size: 28rpx;
    font-weight: bold;
}
/* 结合账号定位 */
.account-setting.data-v-09f76a21 {
    background: transparent;
}
.setting-desc.data-v-09f76a21 {
    font-size: 26rpx;
    color: #999;
}
/* 底部操作栏 */
.bottom-bar.data-v-09f76a21 {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24rpx 40rpx;
    padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
    background: #f8f9fa;
    z-index: 100;
}
.generate-btn.data-v-09f76a21 {
    width: 100%;
    height: 96rpx;
    background: #cdd1dd;
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
    border-radius: 20rpx;
    transition: all 0.3s;
}
.generate-btn.data-v-09f76a21:not(.disabled) {
    background: #1677FF;
    box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
}

