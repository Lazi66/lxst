
.page-container.data-v-02c2c62e {
    background-color: #f8f9fa;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}
.x.data-v-02c2c62e { display: flex; flex-direction: row;
}
.y.data-v-02c2c62e { display: flex; flex-direction: column;
}
.c.data-v-02c2c62e { display: flex; align-items: center; justify-content: center;
}
.c-y.data-v-02c2c62e { align-items: center;
}
.jc-sb.data-v-02c2c62e { justify-content: space-between;
}
.flex-1.data-v-02c2c62e { flex: 1;
}
.m-l-10.data-v-02c2c62e { margin-left: 10rpx;
}
/* 导航栏 */
.nav-left-btn.data-v-02c2c62e {
    padding: 10rpx;
}
.nav-right-btn.data-v-02c2c62e {
    background: #e8ebf0;
    padding: 12rpx 24rpx;
    border-radius: 100rpx;
}
.nav-right-text.data-v-02c2c62e {
    font-size: 24rpx;
    color: #333;
    margin-left: 8rpx;
    font-weight: 500;
}
.content-wrap.data-v-02c2c62e {
    padding: 0 60rpx;
    padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}
/* 手机模拟器 */
.mockup-container.data-v-02c2c62e {
    padding: 40rpx 0 80rpx;
    width: 100%;
}
.phone-mockup.data-v-02c2c62e {
    width: 460rpx;
    height: 700rpx;
    background: #f8f9fa; /* 模拟屏幕底色 */
    border-radius: 60rpx;
    border: 14rpx solid #ffffff; /* 手机外壳 */
    box-shadow: 0 30rpx 60rpx rgba(22, 119, 255, 0.15), inset 0 0 0 2rpx #eee;
    overflow: hidden;
    position: relative;
}
.mockup-header.data-v-02c2c62e {
    padding: 30rpx 24rpx 20rpx;
}
.mockup-title.data-v-02c2c62e {
    font-size: 26rpx;
    font-weight: bold;
    color: #333;
}
.mockup-editor-area.data-v-02c2c62e {
    background: #fff;
    margin: 0 24rpx;
    border-radius: 16rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}
.mockup-input-title.data-v-02c2c62e {
    font-size: 26rpx;
    font-weight: bold;
    color: #333;
}
.mockup-divider.data-v-02c2c62e {
    height: 2rpx;
    background: #f0f0f0;
    margin: 16rpx 0;
}
.mockup-input-desc.data-v-02c2c62e {
    font-size: 22rpx;
    color: #999;
    margin-bottom: 20rpx;
}
.mockup-example-btn.data-v-02c2c62e {
    background: #f0f2f5;
    padding: 8rpx 16rpx;
    border-radius: 8rpx;
    align-self: flex-start;
}
.mockup-bottom-bar.data-v-02c2c62e {
    margin-top: auto;
    background: #fff;
    padding: 20rpx 24rpx;
    border-top: 1rpx solid #f0f0f0;
}
.mockup-ai-btn.data-v-02c2c62e {
    background: #f0f6ff;
    padding: 10rpx 20rpx;
    border-radius: 40rpx;
}
.mockup-ai-text.data-v-02c2c62e {
    font-size: 20rpx;
    color: #1677FF;
    font-weight: 500;
}
.mockup-next-btn.data-v-02c2c62e {
    background: #cdd1dd;
    color: #fff;
    font-size: 20rpx;
    font-weight: bold;
    height: 48rpx;
    padding: 0 30rpx;
    border-radius: 40rpx;
}
/* 底部信息 */
.info-section.data-v-02c2c62e {
    margin-bottom: 60rpx;
}
.info-title-wrap.data-v-02c2c62e {
    margin-bottom: 24rpx;
    display: flex;
    flex-direction: column;
}
.info-title.data-v-02c2c62e {
    font-size: 48rpx;
    font-weight: bold;
    color: #333;
}
.info-title-highlight.data-v-02c2c62e {
    font-size: 48rpx;
    font-weight: bold;
    color: #1677FF;
}
.info-desc.data-v-02c2c62e {
    font-size: 28rpx;
    color: #666;
}
/* 按钮区 */
.bottom-action.data-v-02c2c62e {
    width: 100%;
}
.cta-btn.data-v-02c2c62e {
    width: 100%;
    height: 96rpx;
    background: linear-gradient(135deg, #1677FF, #3A5DFB);
    border-radius: 100rpx;
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
    box-shadow: 0 10rpx 30rpx rgba(22, 119, 255, 0.3);
}

