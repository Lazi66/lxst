/* 算力卡片 */
.wallet-card.data-v-088f60af {
    background: linear-gradient(135deg, #2E5CF6 0%, #573FF4 100%);
    border-radius: 24rpx;
    padding: 40rpx 36rpx;
    height: 320rpx;
    box-sizing: border-box;
    margin-bottom: 30rpx;
    box-shadow: 0 16rpx 32rpx -10rpx rgba(62, 79, 245, 0.4);
}
.card-title.data-v-088f60af {
    font-size: 28rpx;
    color: rgba(255, 255, 255, 0.8);
}
.vip-tag.data-v-088f60af {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 24rpx;
    padding: 6rpx 20rpx;
    border-radius: 100rpx;
}
.c-base.data-v-088f60af {
    line-height: 1;
}
.power-amount.data-v-088f60af {
    font-size: 80rpx;
    font-weight: bold;
    color: #fff;
    margin-right: 12rpx;
}
.power-unit.data-v-088f60af {
    font-size: 28rpx;
    color: rgba(255, 255, 255, 0.8);
    position: relative;
    top: -12rpx;
}
.card-btns.data-v-088f60af {
    width: 100%;
}
.btn-charge.data-v-088f60af {
    width: 47%;
    height: 80rpx;
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 30rpx;
    font-weight: bold;
    border-radius: 16rpx;
}
.btn-vip.data-v-088f60af {
    width: 47%;
    height: 80rpx;
    background: #fff;
    color: #3A5DFB;
    font-size: 30rpx;
    font-weight: bold;
    border-radius: 16rpx;
}
/* 通用区块样式 */
.section-card.data-v-088f60af {
    background: #fff;
    border-radius: 24rpx;
    padding: 40rpx 30rpx 10rpx 30rpx;
}
.section-header.data-v-088f60af {
    margin-bottom: 30rpx;
}
.section-title.data-v-088f60af {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
}
.section-more.data-v-088f60af {
    font-size: 26rpx;
    color: #3A5DFB;
}
/* 列表样式 */
.item-title.data-v-088f60af {
    font-size: 28rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 8rpx;
}
.item-desc.data-v-088f60af {
    font-size: 24rpx;
    color: #999;
}
.icon-box.data-v-088f60af {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
}
.icon-blue.data-v-088f60af { background: #eef1ff;
}
.icon-light-blue.data-v-088f60af { background: #e6f0ff;
}
.bg-purple.data-v-088f60af { background: rgba(160, 58, 251, 0.1);
}
.bg-green.data-v-088f60af { background: rgba(24, 208, 141, 0.1);
