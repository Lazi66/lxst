
.page-container.data-v-82dd5646 {
    background-color: #f8f9fa;
    min-height: 100vh;
    padding-bottom: 140rpx; /* 留出底部按钮空间 */
}
.p-30.data-v-82dd5646 { padding: 30rpx;
}
.m-b-30.data-v-82dd5646 { margin-bottom: 30rpx;
}
.m-b-40.data-v-82dd5646 { margin-bottom: 40rpx;
}
.m-t-30.data-v-82dd5646 { margin-top: 30rpx;
}
.m-r-10.data-v-82dd5646 { margin-right: 10rpx;
}
.x.data-v-82dd5646 { display: flex; flex-direction: row;
}
.y.data-v-82dd5646 { display: flex; flex-direction: column;
}
.c-y.data-v-82dd5646 { align-items: center;
}
.c.data-v-82dd5646 { align-items: center; justify-content: center; display: flex;
}
.jc-sb.data-v-82dd5646 { justify-content: space-between;
}
.jc-c.data-v-82dd5646 { justify-content: center;
}
.flex-1.data-v-82dd5646 { flex: 1;
}
.p-b-safe.data-v-82dd5646 { height: env(safe-area-inset-bottom);
}
/* 通用区块 */
.section-card.data-v-82dd5646 {
    background: #fff;
    border-radius: 24rpx;
    padding: 40rpx 30rpx;
}
.section-title.data-v-82dd5646 {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
}
.section-subtitle.data-v-82dd5646 {
    font-size: 26rpx;
    color: #666;
}
/* 充值金额网格 */
.grid-wrap.data-v-82dd5646 {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
}
.grid-item.data-v-82dd5646 {
    width: 31%;
    height: 140rpx;
    border: 2rpx solid #eee;
    border-radius: 16rpx;
    margin-bottom: 24rpx;
    box-sizing: border-box;
    position: relative;
    transition: all 0.2s;
}
.grid-item.is-active.data-v-82dd5646 {
    border-color: #3A5DFB;
    background: #f5f7ff;
}
.item-price.data-v-82dd5646 {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 8rpx;
}
.item-power.data-v-82dd5646 {
    font-size: 24rpx;
    color: #666;
}
.bonus-text.data-v-82dd5646 {
    color: #ff6b00;
}
.grid-item.is-active .item-price.data-v-82dd5646 {
    color: #3A5DFB;
}
/* 选中角标 */
.check-icon.data-v-82dd5646 {
    position: absolute;
    top: 0;
    right: 0;
    width: 40rpx;
    height: 40rpx;
    background: #3A5DFB;
    border-radius: 0 14rpx 0 16rpx;
}
/* 自定义金额 */
.custom-amount-wrap.data-v-82dd5646 {
    margin-top: 20rpx;
}
.custom-title.data-v-82dd5646 {
    font-size: 28rpx;
    color: #666;
    margin-bottom: 20rpx;
}
.custom-input-box.data-v-82dd5646 {
    border: 2rpx solid #eee;
    border-radius: 16rpx;
    padding: 24rpx 30rpx;
}
.currency-symbol.data-v-82dd5646 {
    font-size: 36rpx;
    color: #333;
    font-weight: bold;
    margin-right: 20rpx;
}
.custom-input.data-v-82dd5646 {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
}
.custom-tip.data-v-82dd5646 {
    font-size: 24rpx;
    color: #999;
    margin-top: 20rpx;
}
/* 支付方式 */
.pay-method-item.data-v-82dd5646 {
    border: 2rpx solid #eee;
    border-radius: 16rpx;
    padding: 30rpx;
    transition: all 0.2s;
}
.pay-method-item.is-active.data-v-82dd5646 {
    border-color: #3A5DFB;
    background: #f5f7ff;
}
.pay-icon.data-v-82dd5646 {
    width: 56rpx;
    height: 56rpx;
    border-radius: 8rpx;
    margin-right: 20rpx;
}
.pay-name.data-v-82dd5646 {
    font-size: 30rpx;
    color: #333;
}
.radio-checked.data-v-82dd5646 {
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    border: 4rpx solid #3A5DFB;
    background: #fff;
}
.radio-inner.data-v-82dd5646 {
    width: 20rpx;
    height: 20rpx;
    border-radius: 50%;
    background: #3A5DFB;
}
/* 提示信息 */
.info-banner.data-v-82dd5646 {
    background: #f5f7ff;
    border-radius: 16rpx;
    padding: 24rpx;
    align-items: flex-start;
}
.info-text.data-v-82dd5646 {
    font-size: 26rpx;
    color: #3A5DFB;
    line-height: 1.6;
}
/* 底部按钮 */
.bottom-fixed.data-v-82dd5646 {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: #f8f9fa;
    padding: 30rpx;
    box-sizing: border-box;
    z-index: 100;
}
.btn-confirm.data-v-82dd5646 {
    width: 100%;
    height: 90rpx;
    background: #3A5DFB;
    border-radius: 16rpx;
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
    box-shadow: 0 8rpx 20rpx rgba(58, 93, 251, 0.3);
}

