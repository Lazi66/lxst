    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.x.data-v-00fd23fe { display: flex; flex-direction: row;
}
.y.data-v-00fd23fe { display: flex; flex-direction: column;
}
.c.data-v-00fd23fe { display: flex; align-items: center; justify-content: center;
}
.c-y.data-v-00fd23fe { align-items: center;
}
.jc-sb.data-v-00fd23fe { justify-content: space-between;
}
.flex-1.data-v-00fd23fe { flex: 1;
}
.m-l-10.data-v-00fd23fe { margin-left: 10rpx;
}
.m-l-20.data-v-00fd23fe { margin-left: 20rpx;
}
.content-wrap.data-v-00fd23fe {
    padding: 30rpx;
    padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
    flex: 1;
    overflow: hidden;
    min-height: 0;
    display: flex;
    flex-direction: column;
}
.editor-area.data-v-00fd23fe {
    background: #fff;
    border-radius: 24rpx;
