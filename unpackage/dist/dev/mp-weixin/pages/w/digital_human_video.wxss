    box-sizing: border-box;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
    flex-shrink: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
}
/* 素材抢先看区域 */
.media-preview-area.data-v-00fd23fe {
    margin-top: 30rpx;
    background: #fff;
    border-radius: 24rpx;
    padding: 30rpx;
    gap: 20rpx;
    box-sizing: border-box;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
    flex-shrink: 0;
}
.flex-wrap.data-v-00fd23fe { flex-wrap: wrap;
}
.media-item.data-v-00fd23fe {
    position: relative;
    width: 140rpx;
    height: 140rpx;
    border-radius: 12rpx;
    overflow: hidden;
    background: #e8e8e8;
}
.media-img.data-v-00fd23fe, .media-video.data-v-00fd23fe {
    width: 100%;
