
.page-container.data-v-b75390e0 {
    background-color: #f8f9fa;
    min-height: 100vh;
}
.x.data-v-b75390e0 { display: flex; flex-direction: row;
}
.y.data-v-b75390e0 { display: flex; flex-direction: column;
}
.c.data-v-b75390e0 { display: flex; align-items: center; justify-content: center;
}
.c-y.data-v-b75390e0 { align-items: center;
}
.jc-sb.data-v-b75390e0 { justify-content: space-between;
}
.flex-1.data-v-b75390e0 { flex: 1;
}
.flex-wrap.data-v-b75390e0 { flex-wrap: wrap;
}
.m-l-20.data-v-b75390e0 { margin-left: 20rpx;
}
.content-wrap.data-v-b75390e0 {
    padding: 40rpx;
    padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
.section-title.data-v-b75390e0 {
    font-size: 34rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 40rpx;
}
/* 空状态 */
.empty-state.data-v-b75390e0 {
    gap: 30rpx;
}
.action-card.data-v-b75390e0 {
    background: #fff;
    border-radius: 24rpx;
    padding: 40rpx 40rpx;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}
.action-card.data-v-b75390e0:active {
    background: #f7f8fa;
}
.action-text.data-v-b75390e0 {
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
}
.skip-btn-wrap.data-v-b75390e0 {
    margin-top: 60rpx;
}
.skip-btn.data-v-b75390e0 {
    border: 2rpx solid #e0e0e0;
    border-radius: 100rpx;
    padding: 12rpx 32rpx;
}
.skip-text.data-v-b75390e0 {
    font-size: 26rpx;
    color: #666;
    margin-right: 8rpx;
}
/* 填充状态 */
.media-grid.data-v-b75390e0 {
    gap: 20rpx;
}
.media-item.data-v-b75390e0 {
    position: relative;
    width: 200rpx;
    height: 200rpx;
    border-radius: 16rpx;
    overflow: hidden;
    background: #e8e8e8;
}
.media-img.data-v-b75390e0, .media-video.data-v-b75390e0 {
    width: 100%;
    height: 100%;
}
.delete-btn.data-v-b75390e0 {
    position: absolute;
    top: 10rpx;
    right: 10rpx;
    width: 36rpx;
    height: 36rpx;
    background: rgba(0,0,0,0.4);
    border-radius: 50%;
    z-index: 10;
}
.add-btn.data-v-b75390e0 {
    width: 200rpx;
    height: 200rpx;
    border-radius: 16rpx;
    border: 2rpx dashed #ccc;
    background: transparent;
}
.add-btn.data-v-b75390e0:active {
    background: #f0f0f0;
}
/* 底部按钮 */
.bottom-bar.data-v-b75390e0 {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24rpx 40rpx;
    padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
    background: #f8f9fa;
    z-index: 100;
}
.next-btn.data-v-b75390e0 {
    width: 100%;
    height: 96rpx;
    background: #1677FF;
    border-radius: 20rpx;
    box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.2);
}
.next-btn.data-v-b75390e0:active {
    opacity: 0.9;
}
.next-text.data-v-b75390e0 {
    font-size: 32rpx;
    color: #fff;
    font-weight: bold;
}

