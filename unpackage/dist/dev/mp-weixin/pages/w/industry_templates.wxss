/* 搜索框 */
.search-box.data-v-7da6b2ae {
    background: #fff;
    border-radius: 100rpx;
    padding: 16rpx 30rpx;
    margin-bottom: 30rpx;
}
.search-input.data-v-7da6b2ae {
    font-size: 26rpx;
    color: #333;
    border: none;
    outline: none;
    background: transparent;
}
/* 分类 Tab */
.tab-scroll.data-v-7da6b2ae {
    width: 100%;
    white-space: nowrap;
    margin-bottom: 20rpx;
}
.tab-wrap.data-v-7da6b2ae {
    display: inline-block;
}
.tab-item.data-v-7da6b2ae {
    display: inline-block;
    padding: 12rpx 36rpx;
    margin-right: 20rpx;
    font-size: 26rpx;
    color: #666;
    background: #fff;
    border-radius: 100rpx;
    transition: all 0.2s;
}
.tab-item.active.data-v-7da6b2ae {
    color: #fff;
    background: #1677FF;
    font-weight: bold;
}
/* 筛选栏 */
.filter-bar.data-v-7da6b2ae {
    margin-bottom: 20rpx;
    gap: 30rpx;
}
.filter-item.data-v-7da6b2ae {
    padding: 8rpx 0;
    gap: 6rpx;
    position: relative;
}
.filter-text.data-v-7da6b2ae {
    font-size: 26rpx;
    color: #999;
}
.filter-item.active .filter-text.data-v-7da6b2ae {
    color: #1677FF;
    font-weight: bold;
}
.sort-arrows.data-v-7da6b2ae {
    gap: 0;
    margin-top: -2rpx;
}
/* 瀑布流布局 */
.waterfall-container.data-v-7da6b2ae {
    -webkit-column-count: 2;
            column-count: 2;
    -webkit-column-gap: 20rpx;
            column-gap: 20rpx;
    width: 100%;
}
.waterfall-item.data-v-7da6b2ae {
    background: #fff;
    border-radius: 16rpx;
    overflow: hidden;
    margin-bottom: 20rpx;
    -webkit-column-break-inside: avoid;
            break-inside: avoid;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.img-box.data-v-7da6b2ae {
    width: 100%;
    box-sizing: border-box;
}
