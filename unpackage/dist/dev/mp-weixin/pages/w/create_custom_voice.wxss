}
.bar.data-v-36517186 {
    width: 6rpx;
    min-height: 10%;
    max-height: 90%;
    background: #1677ff;
    margin: 0 8rpx;
    border-radius: 4rpx;
    /* 无 CSS 动画，完全由 JS 驱动 height 变化 */
}
@-webkit-keyframes bounce-data-v-36517186 {
0% { height: 30%;
}
100% { height: 100%;
}
}
@keyframes bounce-data-v-36517186 {
0% { height: 30%;
}
100% { height: 100%;
}
}
